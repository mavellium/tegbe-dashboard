generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model Company {
  id          String       @id @default(cuid())
  name        String
  
  users       User[]   
  subCompanies SubCompany[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("companies")
}

model SubCompany {
  id          String       @id @default(cuid())
  name        String
  
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  logo_img    String?    
  description String?     
  ga_id       String?   

  theme       Json?
  menuItems   Json?

  blogEnabled Boolean    @default(false)

  formData    FormData[]
  components  Component[]
  pages       Page[]
  blogPosts   BlogPost[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("sub_companies")
}

model Page {
  id           String     @id @default(cuid())
  title        String
  subtitle     String?
  icon         String     @default("FileText") 
  endpoint     String     
  formData     Json?    
  
  subCompanyId String
  subCompany   SubCompany @relation(fields: [subCompanyId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("pages")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String

  role        Role      @default(USER)
  isActive    Boolean   @default(true)
  lastLogin   DateTime?

  forcePasswordChange Boolean  @default(false)

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  posts       BlogPost[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("users")
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogCategory {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String?    @db.Text
  image           String?

  seoTitle        String?
  seoDescription  String?    @db.Text
  seoKeywords     String?

  posts           BlogPost[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("blog_categories")
}

model BlogTag {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?         @db.Text
  image           String?

  seoTitle        String?
  seoDescription  String?         @db.Text
  seoKeywords     String?

  posts           BlogPostTag[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("blog_tags")
}

model BlogPost {
  id              String          @id @default(cuid())
  title           String
  subtitle        String?
  slug            String          @unique
  image           String?
  body            String          @db.Text
  excerpt         String?         @db.Text
  status          BlogPostStatus  @default(DRAFT)
  featured        Boolean         @default(false)
  readingTime     Int?

  // Autor: pode ser um User vinculado OU um nome livre
  authorId        String?
  author          User?           @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName      String?

  // SEO
  seoTitle        String?
  seoDescription  String?         @db.Text
  seoKeywords     String?

  // Relações
  subCompanyId    String?
  subCompany      SubCompany?     @relation(fields: [subCompanyId], references: [id], onDelete: SetNull)

  categoryId      String?
  category        BlogCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            BlogPostTag[]

  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("blog_posts")
}

model BlogPostTag {
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  tagId     String
  tag       BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model FormData {
  id            String      @id @default(cuid())
  values        Json
  type          String
  subtype       String
  createdAt     DateTime    @default(now())

  subCompanyId  String?
  subCompany    SubCompany? @relation(fields: [subCompanyId], references: [id], onDelete: SetNull)

  components    Component[] 

  @@unique([type, subtype, subCompanyId])
}

model Component {
  id            String      @id @default(cuid())
  name          String          
  html          String      @db.Text 
  config        Json            
  
  formDataId    String?
  formData      FormData?   @relation(fields: [formDataId], references: [id], onDelete: SetNull)
  
  subCompanyId  String?
  subCompany    SubCompany? @relation(fields: [subCompanyId], references: [id], onDelete: SetNull)
  
  collectedData ComponentData[] 

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("components")
}

model ComponentData {
  id            String      @id @default(cuid())
  componentId   String?
  component     Component?  @relation(fields: [componentId], references: [id], onDelete: Cascade)
  
  data          Json       
  createdAt     DateTime    @default(now())

  @@map("component_data")
}